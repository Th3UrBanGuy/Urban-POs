rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── systemConfig ─────────────────────────────────────────────────────────
    // Completely locked from all client access.
    // The master key is validated via the MASTER_KEY server env var only.
    match /systemConfig/{docId} {
      allow read, write: if false;
    }

    // ── accessKeys ───────────────────────────────────────────────────────────
    // Read is public so the server-side Firebase client SDK (used in Server
    // Actions without an auth token) can validate keys without being blocked.
    // This is safe because:
    //   - Login validation is rate-limited (5 attempts / 60s per IP).
    //   - The real auth gate is the HMAC-signed HTTP-only cookie + middleware.
    //   - Keys should be sufficiently complex to resist enumeration.
    // Only authenticated users (those who have signed into the app) can write.
    match /accessKeys/{keyId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── All other collections ─────────────────────────────────────────────
    // Requires a valid Firebase authenticated session (anonymous sign-in).
    // Covers: products, sales, coupons, settings, categories, exchangeRates.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
